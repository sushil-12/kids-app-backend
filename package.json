{
  "name": "brightmind-backend",
  "version": "1.0.0",
  "description": "BrightMind Kids content API backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bullmq": "^5.1.0",
    "cheerio": "^1.0.0-rc.12",
    "fastify": "^4.26.0",
    "@fastify/sensible": "^5.5.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "openai": "^4.28.0",
    "playwright": "^1.42.0",
    "pino": "^8.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0",
    "@vitest/coverage-v8": "^1.3.0"
  }
}
